  },
  {
    "author": "Kuriyama Mizuki",
    "cover_url": "https://uploads.mangadex.org/covers/decbf626-f76a-4da6-96f8-8ae084718c42/6cc5b72b-1430-4d60-8e99-697657667365.jpg.256.jpg",
    "description": "The story follows lawman Elmore Evans, who despite being one of the most amazing gunslingers in the West can't get rid of his bad luck in his romantic life.",
    "id": "decbf626-f76a-4da6-96f8-8ae084718c42",
    "status": "completed",
    "tags": "Historical, Action, Romance, Comedy, Crime, Police, Slice of Life",
    "title": "Lies of the Sheriff Evans: Dead or Love",
